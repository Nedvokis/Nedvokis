# Environment for WeasyPrint
# Linux: typically no extra env vars needed if system libs are installed:
#   sudo apt-get install libpango-1.0-0 libpangoft2-1.0-0 libharfbuzz0b libcairo2
#
# macOS (Homebrew, Apple Silicon prefix /opt/homebrew):
# DYLD_FALLBACK_LIBRARY_PATH=/opt/homebrew/lib:/opt/homebrew/opt/glib/lib:/opt/homebrew/opt/pango/lib:/opt/homebrew/opt/cairo/lib:/opt/homebrew/opt/gdk-pixbuf/lib:/opt/homebrew/opt/harfbuzz/lib:/opt/homebrew/opt/graphite2/lib

# Usage:
# 1) cp .env.example .env  (only if you set platform-specific vars above)
# 2) Export before running (bash/zsh):
#    set -a; source .env; set +a
# 3) Build PDFs:
#    uv run scripts/md_to_pdf.py README.md --output CV.pdf --css styles/pdf.css
#    uv run scripts/md_to_pdf.py README_FULL.md --output CV_FULL.pdf --css styles/pdf.css
# 4) Preview HTML in browser:
#    uv run scripts/dev_preview.py --port 8765 --markdown README.md --css styles/pdf.css
